# FluentMind AI Environment Variables
# Copy this to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# The "Publishable / Anon" public key. Safe to use in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publish_anon_key

# The "Secret / Service Role" key. NEVER expose to the browser.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
